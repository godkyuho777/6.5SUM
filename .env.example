# ─────────────────────────────────────────────────────────────
# Tradelab Backend — Local Environment Variables
# Copy this file to `.env` and fill in the values from Supabase.
# `.env` is gitignored, so it stays on your machine only.
# ─────────────────────────────────────────────────────────────

# Express HTTP port. Vite dev proxy targets http://localhost:3000.
PORT=3000

# Optional — set to "production" only on Railway. Leave blank for local dev.
# NODE_ENV=development

# ── Supabase Postgres ────────────────────────────────────────
# DATABASE_URL: pooled connection (port 6543) used by the app at runtime.
# DIRECT_URL:   direct connection (port 5432) used by `drizzle-kit migrate`.
# Get both from Supabase Dashboard → Project Settings → Database → Connection string.
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
DIRECT_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# ── Supabase Auth (server-side) ──────────────────────────────
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated list of Supabase user UUIDs that should have admin access.
ADMIN_USER_IDS=

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated origins allowed to hit /api directly. For local dev with
# Vite's proxy this can be left blank (CORS becomes permissive).
CORS_ORIGIN=http://localhost:5173

# ── OpenRouter (AI Insight feature, optional) ────────────────
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_APP_NAME=Tradelab

# ── Onchain Modifiers (optional, all key-driven) ─────────────
# 키 미설정 시 해당 modifier 는 status="stub" / value=0 (영향 없음).
# Stage 1 즉시 동작 (키 불필요): coinbase_premium, ssr
# Stage 1 후반 통합 예정:
CRYPTOQUANT_API_KEY=     # exchange_netflow + miner_outflow
WHALE_ALERT_API_KEY=     # whale_alert
GLASSNODE_API_KEY=       # lth_supply
ETF_FLOW_PROVIDER=       # "farside" 로 설정하면 BTC/ETH ETF flow 스크래핑 활성화

# ── Onchain Mock Mode (개발/UI 검증 전용) ──────────────────
# "1" 로 설정하면 키 미설정 stub 자리에 결정론(symbol+key hash) mock 값을
# 주입한다. status="mock" 으로 식별되며, 시각화 검증용. 프로덕션 배포 시
# 비워두거나 "0" 으로 둘 것 (실데이터 키가 없으면 stub 으로 자연 fallback).
ONCHAIN_MOCK=

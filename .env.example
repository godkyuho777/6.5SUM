# Tradelab Backend — env template.
# Copy to `.env` and fill values. NEVER commit actual secrets.

# ── Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=

# ── Database (Supabase Postgres)
DATABASE_URL=
DIRECT_URL=
DATABASE_POOL_MAX=10

# ── Supabase auth
SUPABASE_PROJECT_PAT=
SUPABASE_PROJECT_REF=
SUPABASE_URL=
SUPABASE_JWT_SECRET=
SUPABASE_SERVICE_ROLE_KEY=
ADMIN_USER_IDS=

# ── OpenRouter (LLM)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=

# ── v6.5 macro / onchain data sources (PR-2 wiring)
# FRED API key for SOFR / IORB / RRP / TGA / Fed balance / FEDFUNDS / CPI / BOK series.
# Free tier: register at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

{
  "name": "@tradelab/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/types/src/types-entry.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/src/types-entry.d.ts"
    },
    "./router": {
      "types": "./dist/types/src/types-entry.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx watch src/index.ts",
    "build": "pnpm build:server && pnpm build:types",
    "build:server": "esbuild src/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "build:types": "tsc -p tsconfig.types.json",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "check": "tsc --noEmit",
    "format": "prettier --write .",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "backtest": "tsx src/backtest/cli.ts",
    "backtest:quick": "tsx src/backtest/cli.ts --quick"
  },
  "dependencies": {
    "@trpc/server": "^11.6.0",
    "axios": "^1.12.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.2",
    "drizzle-orm": "^0.44.5",
    "express": "^4.21.2",
    "jose": "6.1.0",
    "postgres": "^3.4.4",
    "superjson": "^1.13.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "4.17.21",
    "@types/node": "^24.7.0",
    "@types/qs": "^6.9.18",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.4",
    "esbuild": "^0.25.0",
    "prettier": "^3.6.2",
    "tsx": "^4.19.1",
    "typescript": "5.9.3",
    "vitest": "^2.1.4"
  },
  "packageManager": "pnpm@10.4.1"
}

# Tradelab Backend — env template.
# Copy to `.env` and fill values. NEVER commit actual secrets.

# ── Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=

# ── Database (Supabase Postgres)
DATABASE_URL=
DIRECT_URL=
DATABASE_POOL_MAX=10

# ── Supabase auth
SUPABASE_PROJECT_PAT=
SUPABASE_PROJECT_REF=
SUPABASE_URL=
SUPABASE_JWT_SECRET=
SUPABASE_SERVICE_ROLE_KEY=
ADMIN_USER_IDS=

# ── OpenRouter (LLM)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=

# ── v6.5 macro / onchain data sources (PR-2 wiring)
# FRED API key for SOFR / IORB / RRP / TGA / Fed balance / FEDFUNDS / CPI / BOK series.
# Free tier: register at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# ── Onchain Modifiers (optional, all key-driven)
# 키 미설정 시 해당 modifier 는 status="stub" / value=0 (영향 없음).
# Stage 1 즉시 동작 (키 불필요): coinbase_premium, ssr
# Stage 1 후반 통합 예정:
CRYPTOQUANT_API_KEY=     # exchange_netflow + miner_outflow
WHALE_ALERT_API_KEY=     # whale_alert
GLASSNODE_API_KEY=       # lth_supply
# ETF_FLOW_PROVIDER: "farside" 로 설정하면 BTC/ETH Spot ETF net flow 스크래핑 활성화.
#   - 데이터 소스: https://farside.co.uk/btc/ , https://farside.co.uk/eth/ (무료, 키 불필요).
#   - 임계값: 3d > +$1.5B → +0.20 / 3d < -$1B → -0.25 / 사이는 선형 보간.
#   - 캐싱: 24h 디스크 (`.macro-cache/etf-flow-<symbol>-YYYYMMDD.json`).
#   - 안전: HTML 파싱 실패 / 네트워크 오류 시 status="error", value=0 → BBDX 영향 X.
ETF_FLOW_PROVIDER=

# ── Onchain Mock Mode (개발/UI 검증 전용)
# "1" 로 설정하면 키 미설정 stub 자리에 결정론(symbol+key hash) mock 값을
# 주입한다. status="mock" 으로 식별되며, 시각화 검증용. 프로덕션 배포 시
# 비워두거나 "0" 으로 둘 것 (실데이터 키가 없으면 stub 으로 자연 fallback).
ONCHAIN_MOCK=

# ── SHORT Signals (UI 노출 정책, 2026-05-11 update)
# "0" 으로 설정 시 scanner.ts 의 SHORT 산출 자체를 비활성 (legacy).
# 미설정 또는 "1" (default) 이면 SHORT 시그널이 SIGNAL 컬럼에 배지로 표시 —
# 사용자가 시각 확인 가능. Frontend 가 "검증중" chip 자동 표시.
#
# Production 안전 정책 (이중 보호):
#   1. isRisingKnife 차단 (lowerRiding 외 SHORT 차단)
#   2. BROADCAST_SHORT_ALERTS=1 미설정 시 Lite Alerts 발송 X
#
# 백테스트 결과 (Charter R2 미통과 — alpha 검증중):
#   90d:  winRate 37.0%, Sharpe -0.17, PF 0.66, MDD 40.57%
#   365d: winRate 37.8%, Sharpe -0.25, PF 0.55, MDD 98.85% (RSI 65 + Tier2 -3% 튜닝)
#
# alpha 통과 기준 (winRate ≥ 50%, Sharpe ≥ 0.30, PF ≥ 1.3) 충족 시 본 env 제거
# 가능. Backtest CLI 는 본 flag 무관 (`--strategy bbdx-short`).
ENABLE_SHORT_SIGNALS=

# ── SHORT Alerts Broadcast (production 자본 보호)
# "1" 로 명시 설정 시에만 Lite Alerts / Push notification 으로 SHORT 시그널
# 발송. 미설정/0 이면 alerts 발송 X (UI 표시는 별개).
# alpha 입증 후에만 활성화 권장.
BROADCAST_SHORT_ALERTS=

# ── BBDX v6.6 Feature Flags (BBDX_v66_PERP §4.2)
# v6.5 모듈 보존 + Feature Flag 기반 점진 마이그레이션.
#   BBDX_VERSION=v6.5 (default, 기존 동작) | v6.6 (calibrated weights + threshold)
#   BBDX_MARKET=spot (default, v6.5 호환) | perp (Linear Perp API, 미구현 — 향후 확장)
# v6.6 활성화 시 bbdxV66.current tRPC 라우트가 calibrated weights/threshold 기반 평가 반환.
# 미설정 시 v6.5 fallback note 반환 — production 영향 X.
BBDX_VERSION=
BBDX_MARKET=

# === JEON_IN_GU Signal Tracker (Phase 1.3+ 대기 / D-002) ===
# 명세: JEON_IN_GU_SIGNAL_TRACKER.md.
# 본 트래커는 가중치 ±0.50 (BBDX 100점 시스템 최대 ±50점 영향) 의 6차원 macro modifier.
# 모든 키 옵션. 미설정 시 stub modifier (0) 반환 — BBDX 점수 영향 X.
#
# ⚠️ 안전 장치:
#   - confidence ≥ 0.7 만 적용
#   - 36시간 시간 감쇠
#   - BBDX 최종 신뢰도 ≥ 50 만 진입
#   - 매주 자동 calibration → R² < 0.10 시 가중치 자동 감소 (0.50→0.40→0.30→0.20)
#
# 활성 전 필수 작업 (D-002):
#   1. 변호사 검토 (명예훼손)
#   2. YouTube Data API v3 key 발급
#   3. Anthropic API key 발급 (Claude Haiku 4.5 분류용)
#   4. Telegram bot token + chat id (선택, 알람용)
#   5. 전인구 채널 ID 확인
#
# Feature Flag — false 면 stub modifier 가 강제 0 반환 (모든 키 설정해도).
ENABLE_JEON_IN_GU=false

# YouTube Data API v3 — Phase 1.3 폴링 / Phase 1.4 자막 fetcher.
# 발급: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# 전인구경제연구소 YouTube 채널 ID — UC... 형식.
# 본인이 직접 확인 후 입력 (자동 추출 X).
JEON_IN_GU_CHANNEL_ID=

# Anthropic API key — Phase 2 LLM 감정 분류 (Claude Haiku 4.5).
# 발급: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Telegram bot — Phase 1.6 새 영상 알람 + Phase 2 감정 분류 결과 알람.
# 발급: @BotFather (Telegram) → /newbot → token 발급
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord webhook — 선택 채널 (Phase 7 사용자 알람 구독에서 옵션).
DISCORD_WEBHOOK_URL=

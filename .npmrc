# Use a flat node_modules layout so tsc can write portable .d.ts references
# during `pnpm build:types`. With pnpm's default symlinked layout, transitive
# type packages (e.g. @types/qs reached via @types/express) resolve through
# .pnpm/... and TypeScript emits TS2742 errors for inferred tRPC procedure
# types that pull in Express's request types.
node-linker=hoisted
